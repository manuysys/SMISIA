#include <Wire.h>
#include <Adafruit_Sensor.h>
#include <Adafruit_BME280.h>
#include <Adafruit_SHT31.h>
#include "MHZCO2.h" // Librería de Rob Tillaart

// Instancias de los sensores
Adafruit_BME280 bme;
Adafruit_SHT31 sht30 = Adafruit_SHT31();
MHZ19 mhz19; // Clase específica para tu modelo dentro de la librería MHZCO2

// --- Configuración MPU6050 ---
const float UMBRAL_MOVIMIENTO = 18.0; 

// --- Configuración CO2 ---
int co2Anterior = 0;
const int DELTA_CO2_ALERTA = 50; 

// --- Variables para el control de tiempo ---
unsigned long tiempoAnterior = 0;
const long intervaloClima = 2000; // 2 segundos

bool bme_ok = true;

void checkBME(float t, float h, float p) {
  if (t == 0 && h == 0 && p == 0) {
    bme_ok = false;
  }
}

bool iniciarBME() {
  for (int i = 0; i < 5; i++) {
    if (bme.begin(0x76) || bme.begin(0x77)) {
      return true;
    }
    delay(500);
  }
  return false;
}

void setup() {
  Serial.begin(115200);
  delay(2000); 

  Serial.println();
  Serial.println("Iniciando CubeCell + BME280 + SHT30 + MPU6050 + MH-Z19B (Rob Tillaart)...");

  // 1. Encender VEXT para sensores I2C (3.3V)
  pinMode(Vext, OUTPUT);
  digitalWrite(Vext, LOW); 

  delay(200); // Estabilización de energía

  // 2. Iniciar el bus I2C
  Wire.begin();
  Wire.setClock(50000);

  // 3. Iniciar UART para el MH-Z19B
  Serial1.begin(9600);
  mhz19.begin(&Serial1); // Se pasa la dirección de memoria del puerto Serial1
  Serial.println("✅ MH-Z19B inicializado por UART.");

  // --- Inicializar BME280 ---
  if (!iniciarBME()) {
    Serial.println("❌ BME no detectado.");
  } else {
    Serial.println("✅ BME280 detectado.");
  }

  // --- Inicializar SHT30 ---
  if (!sht30.begin(0x44)) {
    Serial.println("❌ No se encontró el SHT30 en 0x44.");
  } else {
    Serial.println("✅ SHT30 detectado.");
  }

  // --- Inicializar MPU6050 Directamente por Hardware (Wire) ---
  Wire.beginTransmission(0x68); 
  Wire.write(0x6B);             
  Wire.write(0x00);             
  byte errorMPU = Wire.endTransmission(true);

  if (errorMPU == 0) {
    Serial.println("✅ MPU6050 detectado y despertado exitosamente.");
    Wire.beginTransmission(0x68);
    Wire.write(0x1C); 
    Wire.write(0x08); // Rango +-4G
    Wire.endTransmission(true);
  } else {
    Serial.println("❌ No se encontró el MPU6050 en 0x68.");
  }
  
  Serial.println("=====================================");
}

void loop() {
  // =========================================================
  // TAREA 1: LECTURA RÁPIDA (Detectar movimiento)
  // =========================================================
  
  Wire.beginTransmission(0x68);
  Wire.write(0x3B); 
  Wire.endTransmission(false); 
  
  Wire.requestFrom((uint16_t)0x68, (size_t)6, true);
  
  if (Wire.available() >= 6) {
    int16_t ax_raw = Wire.read() << 8 | Wire.read();
    int16_t ay_raw = Wire.read() << 8 | Wire.read();
    int16_t az_raw = Wire.read() << 8 | Wire.read();

    float ax = (ax_raw / 8192.0) * 9.81;
    float ay = (ay_raw / 8192.0) * 9.81;
    float az = (az_raw / 8192.0) * 9.81;

    float magnitudAceleracion = sqrt(pow(ax, 2) + pow(ay, 2) + pow(az, 2));

    if (magnitudAceleracion > UMBRAL_MOVIMIENTO) {
      Serial.println("\n🚨 ¡ALERTA! MOVIMIENTO BRUSCO DETECTADO 🚨");
      Serial.print("Fuerza del impacto: "); 
      Serial.print(magnitudAceleracion); 
      Serial.println(" m/s^2");
      Serial.println("------------------------------------------");
      delay(500); 
    }
  }

  // =========================================================
  // TAREA 2: LECTURA LENTA (Clima y CO2)
  // =========================================================
  unsigned long tiempoActual = millis();

  if (tiempoActual - tiempoAnterior >= intervaloClima) {
    tiempoAnterior = tiempoActual;

    // --- Leer Clima ---
    float temp_bme = bme.readTemperature();
    float hum_bme = bme.readHumidity();
    float pres_bme = bme.readPressure() / 100.0F;

    checkBME(temp_bme, hum_bme, pres_bme);

    float temp_sht = sht30.readTemperature();
    float hum_sht = sht30.readHumidity();

    // --- Leer CO2 (Estilo Rob Tillaart) ---
    mhz19.measure(); // IMPORTANTE: Pedirle al sensor que haga la lectura
    int co2Actual = mhz19.getCO2();
    int temp_mhz = mhz19.getTemperature();

    // --- Imprimir Resultados ---
    Serial.println("\n----- Monitoreo Ambiental Silo Bolsa -----");
    
    // BME280
    Serial.println("[ BME280 ]");
    Serial.print("  Humedad:     "); Serial.print(hum_bme); Serial.println(" %");
    Serial.print("  Presión:     "); Serial.print(pres_bme); Serial.println(" hPa");

    if (!bme_ok) {
      Serial.println("  ⚠️ Reiniciando BME...");
      iniciarBME();
      bme_ok = true;
    }

    // SHT30
    Serial.println("[ SHT30 ]");
    if (!isnan(temp_sht)) { 
      Serial.print("  Temperatura: "); Serial.print(temp_sht); Serial.println(" °C");
    } else {
      Serial.println("  ⚠️ Error al leer el SHT30.");
    }

    // MH-Z19B
    Serial.println("[ MH-Z19B ]");
    // La librería suele devolver 0 o valores muy extraños si no hay conexión real
    if (co2Actual > 0) {
      Serial.print("  Nivel CO2:   "); Serial.print(co2Actual); Serial.println(" ppm");
      
      if (co2Anterior > 0 && (co2Actual - co2Anterior > DELTA_CO2_ALERTA)) {
        Serial.println("  🚨 ¡ALERTA! Aumento rápido de CO2 (Actividad Biológica)");
      }
      co2Anterior = co2Actual;
    } else {
      Serial.println("  Calentando sensor o error de conexión UART...");
    }
    
    Serial.println("------------------------------------------");
  }

  delay(50); // Pausa de estabilidad
}
