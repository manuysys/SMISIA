#define PIN_INTERRUPCION GPIO5 // Pin conectado al INT del MPU6050

volatile bool impactoDetectado = false; // Bandera volátil para la interrupción
bool bme_ok = true;

// ================== FUNCIONES AUXILIARES ==================

// Función que se ejecuta INSTANTÁNEAMENTE cuando el pin INT recibe la señal
void ISR_Movimiento() {
  impactoDetectado = true;
}

bool iniciarBME() {
  for (int i = 0; i < 5; i++) {
    if (bme.begin(0x76) || bme.begin(0x77)) return true;
    delay(500);
  }
  return false;
}

// Configuración avanzada del MPU6050 para Wake-On-Motion (Interrupción por hardware)
void configurarMPU6050_Centinela() {
  Wire.beginTransmission(0x68);
  Wire.write(0x6B); Wire.write(0x00); // 1. Despertar MPU
  Wire.endTransmission();

  Wire.beginTransmission(0x68);
  Wire.write(0x1C); Wire.write(0x01); // 2. Filtro paso alto (elimina la gravedad constante)
  Wire.endTransmission();

  Wire.beginTransmission(0x68);
  Wire.write(0x1F); Wire.write(20);   // 3. Umbral de movimiento (Ajustar este valor si es muy sensible)
  Wire.endTransmission();

  Wire.beginTransmission(0x68);
  Wire.write(0x20); Wire.write(1);    // 4. Duración del movimiento (1 ms)
  Wire.endTransmission();

  Wire.beginTransmission(0x68);
  Wire.write(0x37); Wire.write(0x00); // 5. Configurar pin INT (Pulso corto de 50us)
  Wire.endTransmission();

  Wire.beginTransmission(0x68);
  Wire.write(0x38); Wire.write(0x40); // 6. Habilitar la interrupción por movimiento
  Wire.endTransmission();
}

// ================== PREPARACIÓN DEL PAQUETE LORA ==================
void prepareTxFrame(uint8_t port)
{
  float temp = sht30.readTemperature();
  float hum = sht30.readHumidity();
  float pres = bme.readPressure() / 100.0F;
  mhz19.measure();
  int co2 = mhz19.getCO2();

  Serial.println("\n--- 📡 Datos listos para enviar ---");
  Serial.print("Motivo: "); Serial.println(impactoDetectado ? "ALERTA DE IMPACTO" : "Lectura de rutina");
  
  int t = temp * 100;
  int h = hum * 100;
  int p = pres; 

  appDataSize = 9; // Aumentamos a 9 bytes

  appData[0] = highByte(t);
  appData[1] = lowByte(t);
  appData[2] = highByte(h);
  appData[3] = lowByte(h);
  appData[4] = highByte(p);
  appData[5] = lowByte(p);
  appData[6] = highByte(co2);
  appData[7] = lowByte(co2);
  // Byte 8: Bandera de alarma (1 si fue por golpe, 0 si es normal)
  appData[8] = impactoDetectado ? 1 : 0; 
}

void setup() {
  Serial.begin(115200);
  delay(2000);
  Serial.println("\nIniciando Nodo LoRaWAN Multi-Sensor con Wake-on-Motion...");

  pinMode(Vext, OUTPUT);
  digitalWrite(Vext, LOW);
  delay(200);

  Wire.begin();
  Wire.setClock(50000);

  Serial1.begin(9600);
  mhz19.begin(&Serial1);

  iniciarBME();
  sht30.begin(0x44);

  // Configurar MPU6050 y el pin de interrupción en la CubeCell
  configurarMPU6050_Centinela();
  pinMode(PIN_INTERRUPCION, INPUT_PULLDOWN);
  attachInterrupt(digitalPinToInterrupt(PIN_INTERRUPCION), ISR_Movimiento, RISING);
  Serial.println("✅ MPU6050 Centinela activado en GPIO5.");

  deviceState = DEVICE_STATE_INIT;
}

void loop() {
  
  // Si la interrupción disparó la bandera, forzamos el envío inmediatamente
  if (impactoDetectado && deviceState == DEVICE_STATE_SLEEP) {
    Serial.println("\n🚨 ¡DESPERTANDO POR IMPACTO! Enviando datos de emergencia...");
    deviceState = DEVICE_STATE_SEND; // Rompe el sueño y manda directo a enviar
  }

  switch (deviceState)
  {
    case DEVICE_STATE_INIT:
      LoRaWAN.init(loraWanClass, loraWanRegion);
      break;
    case DEVICE_STATE_JOIN:
      LoRaWAN.join();
      break;
    case DEVICE_STATE_SEND:
      prepareTxFrame(appPort);
      LoRaWAN.send();
      deviceState = DEVICE_STATE_CYCLE;
      break;
    case DEVICE_STATE_CYCLE:
      txDutyCycleTime = appTxDutyCycle;
      LoRaWAN.cycle(txDutyCycleTime);
      deviceState = DEVICE_STATE_SLEEP;
      break;
    case DEVICE_STATE_SLEEP:
      // Solo limpiamos la bandera si el ciclo de sueño terminó por tiempo natural
      // (si se despertó por impacto, la bandera la limpiará el siguiente ciclo)
      if (impactoDetectado) {
        impactoDetectado = false; 
      }
      LoRaWAN.sleep(); // ¡A dormir! Se despertará por tiempo o por la interrupción
      break;
    default:
      deviceState = DEVICE_STATE_INIT;
      break;
  }
}
